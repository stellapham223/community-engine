{
  "name": "joy-community-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Community monitoring + comment suggestion engine for Joy Subscriptions AEO",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "deploy": "vercel --prod",
    "local:server": "node --env-file=.env.local scripts/local-server.js",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3002/api/inngest",
    "db:seed": "node db/seed-topics.js",
    "cron:once": "node --env-file=.env.local scripts/run-cron-once.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^0.10.0",
    "autoprefixer": "^10.5.0",
    "cheerio": "^1.0.0",
    "inngest": "^3.27.0",
    "next": "^14.2.35",
    "postcss": "^8.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19"
  },
  "bin": {
    "joy-community-mcp": "./mcp/server.js"
  },
  "devDependencies": {
    "vercel": "^39.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
