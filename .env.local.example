# Copy to .env.local and fill values

# Neon Postgres (https://neon.tech)
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/joy_community_engine?sslmode=require

# Reddit OAuth (https://www.reddit.com/prefs/apps — create "script" app)
# If reddit.com is blocked on your network, try mobile hotspot or VPN
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Slack Bot API (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...

# Anthropic (only needed for MCP tools that hit API; not used in cron)
ANTHROPIC_API_KEY=

# Inngest (set in Inngest dashboard for production; optional for local dev)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
